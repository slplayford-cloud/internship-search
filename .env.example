# Copy to .env and fill in. .env is gitignored; this file is not, so keep real values out of it.

# --- Sources: the raw README of each repo the scraper reads -------------------------------------
SUMMER2027_URL="https://raw.githubusercontent.com/vanshb03/Summer2027-Internships/refs/heads/dev/README.md"
SPEEDYAPPLY_URL="https://raw.githubusercontent.com/speedyapply/2027-SWE-College-Jobs/refs/heads/main/README.md"

# --- Notifications -----------------------------------------------------------------------------
# The topic every phone subscribes to. On the public server the topic name is the ONLY thing
# keeping the feed private: anyone who knows it can read (and post to) it. Generate an unguessable
# one and never commit it:
#
#     openssl rand -hex 16
#
NTFY_TOPIC="CHANGE-ME-to-an-unguessable-topic"

# Optional. Point at a self-hosted ntfy instead of the public server. Must be https:// unless you
# also set NTFY_ALLOW_INSECURE=1 (only sensible for a trusted server on your own network).
#NTFY_SERVER="https://ntfy.example.com"

# Optional. Access token, sent as "Authorization: Bearer ...". Needed for a protected/reserved
# topic on ntfy.sh or an authenticated self-hosted server.
#NTFY_TOKEN="tk_..."
